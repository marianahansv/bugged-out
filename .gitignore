# keeps local, generated, and machine-specific files out of version control.
# this file ignores dependencies, builds, uploads, environment secrets, and os metadata.

node_modules/
frontend/node_modules
backend/node_modules
frontend/build/
backend/uploads/*
!backend/uploads/.gitkeep

.env
backend/.env
frontend/.env

.aider.conf.yml
CONVENTIONS.md

.DS_Store
*.log
.aider*
