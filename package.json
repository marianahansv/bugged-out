{
  "name": "buggedout",
  "private": true,
  "packageManager": "bun@1.3.4",
  "scripts": {
    "install:all": "bun install --cwd backend && bun install --cwd frontend",
    "dev": "bun run scripts/dev.js",
    "dev:backend": "cd backend && bun run dev",
    "dev:frontend": "cd frontend && REACT_APP_API_URL=${REACT_APP_API_URL:-http://localhost:5001} bun run dev",
    "build": "cd frontend && bun run build"
  },
  "dependencies": {
    "express-rate-limit": "^8.5.2"
  }
}
